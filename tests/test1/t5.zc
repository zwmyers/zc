fun fact(n) {
	if (n <= 1) { 
		return 1; 
	}
	return n * fact(n - 1);
}

fun main() {
	let a = 1;
	while (a < 5) {
		print(fact(a));
		a = a + 1;
	}
	let b = fact(a);
	if (fact(a) > b) {
		print(0);	
	} else if (fact(a) < b) {
		print(1);
	} else {
		print(fact(a));
	}
	return 0;
}

let finish = 0;

if (main() != 0) {
	print(finish);
} else {
	finish = 1;
}
