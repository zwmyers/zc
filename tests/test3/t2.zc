fun print_arr(arr, arr_len) {
	let counter = 0;
	while (counter < arr_len) {
		print(arr[counter]);
		counter = counter + 1;
	}
}

fun swap(arr, i, j) {
	let temp = arr[i];
	arr[i] = arr[j];
	arr[j] = temp;
}

fun main() {
	let a = [1, 2, 3, 4, 5];
	print_arr(a, 5);
	swap(a, 0, 4);
	print_arr(a, 5);
}

main();
